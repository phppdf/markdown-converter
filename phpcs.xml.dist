<?xml version="1.0"?>
<ruleset name="html-converter">
    <description>The coding standards of phppdf/html-converter</description>

    <arg value="p"/>
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="80"/>
    <arg name="cache" value=".phpcs.cache"/>
    <arg name="colors"/>

    <file>src/</file>
    <file>tests/</file>

    <rule ref="PhpPdf"/>
</ruleset>
